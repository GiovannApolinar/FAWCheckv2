    },
    "managedEnvironmentName": {
      "type": "string",
      "metadata": {
        "description": "Azure Container Apps managed environment name."
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Azure Storage Account name used for assessment images."
